# ─────────────────────────────────────────────
# Supabase
# Get these from: https://supabase.com/dashboard → your project → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side ONLY. Never expose to the browser.
# Used for analytics queries that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# Database (Prisma)
# Get from: Supabase → Settings → Database → Connection string (URI mode)
# Replace [YOUR-PASSWORD] with your actual database password.
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ─────────────────────────────────────────────
# PostHog — Analytics & Event Tracking
# Get from: https://app.posthog.com → your project → Settings → Project API Key
# ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
